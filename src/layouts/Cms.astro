---
const { title = "CMS — Blog Templum", auth = true } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style is:global>
      :root { --orange:#B23C0C; --navy:#222831; --bg:#f6f7f9; --card:#fff; --border:#e5e7eb; --text:#18191B; --soft:#6b7280; }
      * { box-sizing:border-box; margin:0; padding:0; }
      body { font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; background:var(--bg); color:var(--text); }
      a { color:var(--orange); text-decoration:none; }
      .top { background:var(--navy); color:#fff; padding:12px 22px; display:flex; align-items:center; gap:20px; }
      .top b { font-weight:800; }
      .top nav { display:flex; gap:16px; margin-left:8px; }
      .top nav a { color:rgba(255,255,255,.8); font-size:14px; font-weight:600; }
      .top nav a:hover { color:#fff; }
      .top .sp { margin-left:auto; display:flex; gap:12px; align-items:center; font-size:13px; color:rgba(255,255,255,.7); }
      .wrap { max-width:1100px; margin:0 auto; padding:28px 22px; }
      .btn { display:inline-flex; align-items:center; gap:6px; background:var(--orange); color:#fff; border:0; border-radius:8px; padding:10px 18px; font-size:14px; font-weight:700; cursor:pointer; }
      .btn:hover { filter:brightness(1.05); }
      .btn--ghost { background:#fff; color:var(--text); border:1px solid var(--border); }
      .btn--sm { padding:6px 12px; font-size:13px; }
      .card { background:var(--card); border:1px solid var(--border); border-radius:12px; }
      input, textarea, select { width:100%; font:inherit; padding:10px 12px; border:1px solid var(--border); border-radius:8px; background:#fff; }
      label { display:block; font-size:13px; font-weight:700; margin:14px 0 6px; }
      table { width:100%; border-collapse:collapse; }
      th,td { text-align:left; padding:11px 14px; border-bottom:1px solid var(--border); font-size:14px; }
      th { font-size:12px; text-transform:uppercase; letter-spacing:.05em; color:var(--soft); }
      .pill { font-size:11px; font-weight:700; padding:3px 9px; border-radius:999px; }
      .pill--pub { background:#dcfce7; color:#15803d; }
      .pill--draft { background:#fef3c7; color:#92600e; }
      .muted { color:var(--soft); font-size:13px; }
    </style>
  </head>
  <body>
    {auth && (
      <header class="top">
        <b>Templum · CMS</b>
        <nav>
          <a href="/">Artigos</a>
          <a href="/colaboradores/">Colaboradores</a>
        </nav>
        <div class="sp"><span id="whoami"></span><button class="btn btn--ghost btn--sm" id="logout">Sair</button></div>
      </header>
    )}
    <div class="wrap"><slot /></div>

    {auth && (
      <script>
        import { supabase, requireAuth } from "../lib/supabase.js";
        const s = await requireAuth();
        if (s) {
          const el = document.getElementById("whoami");
          if (el) el.textContent = s.user.email;
          document.getElementById("logout")?.addEventListener("click", async () => {
            await supabase.auth.signOut(); location.href = "/login/";
          });
        }
      </script>
    )}
  </body>
</html>

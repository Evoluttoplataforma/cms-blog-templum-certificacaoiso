---
const { title = "Painel", active = "" } = Astro.props;
const B = "/acesso";
const nav = [
  { id: "artigos", label: "Artigos", icon: "file-text", href: `${B}/artigos` },
  { id: "iscas", label: "Iscas", icon: "gift", href: `${B}/iscas` },
  { id: "historias", label: "Histórias", icon: "sparkles", href: `${B}/historias` },
  { id: "comentarios", label: "Comentários", icon: "message-square", href: `${B}/comentarios` },
  { id: "banners", label: "Banners", icon: "image", href: `${B}/banners` },
];
const navBottom = [
  { id: "usuarios", label: "Usuários", icon: "users", href: `${B}/usuarios` },
  { id: "blog", label: "Ver Blog", icon: "external-link", href: "https://certificacaoiso.com.br", ext: true },
  { id: "site", label: "Ver Site", icon: "external-link", href: "https://templum.com.br", ext: true },
];
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Templum CMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#F3F3F1] font-sans text-brand-navy antialiased">
    <!-- SIDEBAR -->
    <aside class="hidden lg:flex w-64 fixed inset-y-0 left-0 bg-brand-navy text-gray-300 flex-col">
      <div class="px-6 py-5 flex items-center gap-2 border-b border-white/10">
        <img src={`${B}/logo.png`} alt="Templum" class="h-7 brightness-0 invert" />
        <span class="text-[0.6rem] font-extrabold tracking-widest bg-brand-orange/20 text-brand-orange px-2 py-0.5 rounded">CMS</span>
      </div>
      <nav class="flex-1 px-3 py-5 space-y-1 overflow-y-auto">
        {nav.map((n) => (
          <a href={n.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition ${active === n.id ? "bg-brand-orange/15 text-brand-orange ring-1 ring-brand-orange/30" : "text-gray-400 hover:text-white hover:bg-white/5"}`}>
            <i data-lucide={n.icon} class="w-[18px] h-[18px]"></i>{n.label}
          </a>
        ))}
        <div class="my-4 border-t border-white/10"></div>
        {navBottom.map((n) => (
          <a href={n.href} target={n.ext ? "_blank" : null} rel={n.ext ? "noopener" : null} class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition ${active === n.id ? "bg-brand-orange/15 text-brand-orange ring-1 ring-brand-orange/30" : "text-gray-400 hover:text-white hover:bg-white/5"}`}>
            <i data-lucide={n.icon} class="w-[18px] h-[18px]"></i>{n.label}
          </a>
        ))}
      </nav>
      <div class="px-4 py-4 border-t border-white/10 flex items-center gap-3">
        <span id="sb-avatar" class="w-9 h-9 rounded-full bg-brand-gradient grid place-items-center text-white text-xs font-bold">··</span>
        <div class="min-w-0 flex-1">
          <p id="sb-name" class="text-sm font-semibold text-white truncate">—</p>
          <p id="sb-role" class="text-xs text-gray-500">—</p>
        </div>
        <button id="logout" title="Sair" class="text-gray-400 hover:text-white"><i data-lucide="log-out" class="w-[18px] h-[18px]"></i></button>
      </div>
    </aside>

    <!-- CONTEÚDO -->
    <div class="lg:ml-64 min-h-screen flex flex-col">
      <header class="sticky top-0 z-20 bg-white border-b border-gray-200 h-[68px] px-6 flex items-center justify-between">
        <h1 class="text-lg font-extrabold tracking-tight">{title}</h1>
        <div class="flex items-center gap-2"><slot name="actions" /></div>
      </header>
      <main class="flex-1 p-6"><slot /></main>
    </div>

    <script>
      import { createIcons, icons } from "lucide";
      createIcons({ icons });
    </script>
    <script>
      import { supa, requireAuth, BASE } from "../lib/supa.ts";
      const s = await requireAuth();
      if (s) {
        const email = s.user.email || "";
        const ini = email.slice(0, 2).toUpperCase();
        document.getElementById("sb-avatar")!.textContent = ini;
        document.getElementById("sb-name")!.textContent = email.split("@")[0];
        document.getElementById("sb-role")!.textContent = email;
        document.getElementById("logout")!.addEventListener("click", async () => {
          await supa.auth.signOut(); window.location.href = BASE + "/login";
        });
      }
    </script>
  </body>
</html>

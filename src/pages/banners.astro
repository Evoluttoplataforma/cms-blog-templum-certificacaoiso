---
import CmsLayout from "../layouts/CmsLayout.astro";
---
<CmsLayout title="Banners" active="banners">
  <button slot="actions" id="new" class="px-4 py-2 rounded-full bg-brand-ink text-white text-sm font-bold shadow-lg hover:brightness-110 flex items-center gap-1.5"><i data-lucide="plus" class="w-4 h-4"></i> Novo banner</button>
  <div id="grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"><p class="text-sm text-gray-400">Carregando…</p></div>

  <dialog id="dlg" class="rounded-2xl p-0 w-full max-w-md backdrop:bg-black/40">
    <form id="form" class="p-6 space-y-3">
      <h3 class="font-extrabold text-lg" id="dlg-title">Novo banner</h3>
      <input type="hidden" id="id" />
      <div><label class="lb">Título</label><input id="title" class="inp" /></div>
      <div>
        <label class="lb">Imagem</label>
        <div id="prev" class="aspect-[16/7] rounded-lg bg-gray-100 mb-2 bg-cover bg-center"></div>
        <div class="flex gap-2"><input id="image_url" class="inp flex-1" placeholder="URL ou enviar →" /><button type="button" id="up" class="px-3 rounded-lg border border-gray-300"><i data-lucide="upload" class="w-4 h-4"></i></button></div>
      </div>
      <div><label class="lb">Link</label><input id="link_url" class="inp" placeholder="https://templum.com.br/form" /></div>
      <div><label class="lb">Posição</label><input id="position" class="inp" placeholder="sidebar / home / artigo" /></div>
      <label class="flex items-center gap-2 text-sm"><input type="checkbox" id="active" checked /> Ativo</label>
      <div class="flex gap-2 justify-end pt-2"><button type="button" id="cancel" class="px-4 py-2 rounded-full border border-gray-300 text-sm font-bold">Cancelar</button><button type="submit" class="px-4 py-2 rounded-full bg-brand-ink text-white text-sm font-bold">Salvar</button></div>
    </form>
  </dialog>
  <style>.lb{display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:4px}.inp{width:100%;padding:8px 10px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px}.inp:focus{outline:none;border-color:#FF5925}</style>

  <script>
    import { supa, requireAuth, uploadMedia, esc } from "../lib/supa.ts";
    import { createIcons, icons } from "lucide";
    const s = await requireAuth();
    if (s) {
      const T = "blog_templum_banners", grid = document.getElementById("grid"), dlg = document.getElementById("dlg"), form = document.getElementById("form");
      const $ = (id) => document.getElementById(id);
      async function load() {
        const { data, error } = await supa.from(T).select("*").order("created_at", { ascending: false });
        if (error) { grid.innerHTML = `<p class="text-sm text-red-600">${esc(error.message)}</p>`; return; }
        grid.innerHTML = (data && data.length) ? data.map((b) => `
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="aspect-[16/7] bg-gray-100 bg-cover bg-center" style="background-image:url('${esc(b.image_url) || ""}')"></div>
            <div class="p-4">
              <div class="flex items-center justify-between gap-2">
                <p class="font-semibold text-sm truncate">${esc(b.title) || "(sem título)"}</p>
                <button data-toggle="${b.id}" data-v="${b.active}" class="text-[0.65rem] font-bold px-2 py-0.5 rounded-full ${b.active ? "bg-green-100 text-green-700" : "bg-gray-200 text-gray-600"}">${b.active ? "Ativo" : "Inativo"}</button>
              </div>
              <p class="text-xs text-gray-400 mt-1">${esc(b.position) || "—"}</p>
              <div class="flex gap-2 mt-3">
                <button data-edit='${esc(JSON.stringify(b))}' class="px-3 py-1.5 rounded-full border border-gray-300 text-xs font-bold">Editar</button>
                <button data-del="${b.id}" class="px-3 py-1.5 rounded-full border border-red-200 text-red-600 text-xs font-bold">Excluir</button>
              </div>
            </div>
          </div>`).join("") : '<p class="text-sm text-gray-400">Nenhum banner.</p>';
        grid.querySelectorAll("[data-toggle]").forEach((x) => x.addEventListener("click", async () => { await supa.from(T).update({ active: x.dataset.v !== "true" }).eq("id", x.dataset.toggle); load(); }));
        grid.querySelectorAll("[data-del]").forEach((x) => x.addEventListener("click", async () => { if (confirm("Excluir banner?")) { await supa.from(T).delete().eq("id", x.dataset.del); load(); } }));
        grid.querySelectorAll("[data-edit]").forEach((x) => x.addEventListener("click", () => openForm(JSON.parse(x.dataset.edit))));
      }
      function setPrev(u) { $("prev").style.backgroundImage = u ? `url("${u}")` : ""; }
      function openForm(d = {}) {
        $("dlg-title").textContent = d.id ? "Editar banner" : "Novo banner";
        for (const k of ["id", "title", "image_url", "link_url", "position"]) $(k).value = d[k] || "";
        $("active").checked = d.id ? !!d.active : true; setPrev(d.image_url); dlg.showModal();
      }
      $("image_url").addEventListener("input", (e) => setPrev(e.target.value));
      $("up").addEventListener("click", () => { const i = document.createElement("input"); i.type = "file"; i.accept = "image/*"; i.onchange = async () => { if (!i.files?.[0]) return; try { const u = await uploadMedia(i.files[0], "banners"); $("image_url").value = u; setPrev(u); } catch (e) { alert("Erro upload (bucket 'media'?): " + e.message); } }; i.click(); });
      document.getElementById("new").addEventListener("click", () => openForm());
      document.getElementById("cancel").addEventListener("click", () => dlg.close());
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const row = { title: $("title").value || null, image_url: $("image_url").value || null, link_url: $("link_url").value || null, position: $("position").value || "sidebar", active: $("active").checked };
        const id = $("id").value;
        const res = id ? await supa.from(T).update(row).eq("id", id) : await supa.from(T).insert(row);
        if (res.error) alert(res.error.message); else { dlg.close(); load(); }
      });
      load(); createIcons({ icons });
    }
  </script>
</CmsLayout>

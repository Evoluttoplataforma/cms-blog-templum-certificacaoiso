---
import Cms from "../layouts/Cms.astro";
---
<Cms title="Colaboradores — CMS Templum">
  <h1 style="font-size:24px;font-weight:800;margin-bottom:18px;">Colaboradores</h1>

  <div class="card" style="padding:20px;margin-bottom:22px;">
    <b>Convidar colaborador</b>
    <p class="muted" style="margin:4px 0 14px;">Cria o acesso via Supabase Auth e envia o convite por e-mail.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr 160px auto;gap:10px;align-items:end;">
      <div><label style="margin-top:0;">Nome</label><input id="name" /></div>
      <div><label style="margin-top:0;">E-mail</label><input id="email" type="email" /></div>
      <div><label style="margin-top:0;">Papel</label><select id="role"><option value="editor">Editor</option><option value="admin">Admin</option></select></div>
      <button class="btn" id="invite">Convidar</button>
    </div>
    <p id="msg" class="muted" style="margin-top:10px;"></p>
  </div>

  <div class="card">
    <table>
      <thead><tr><th>Nome</th><th>E-mail</th><th>Papel</th><th></th></tr></thead>
      <tbody id="rows"><tr><td colspan="4" class="muted" style="padding:24px;">Carregando…</td></tr></tbody>
    </table>
  </div>

  <script>
    import { supabase, requireAuth } from "../lib/supabase.js";
    await requireAuth();
    const rows = document.getElementById("rows"), msg = document.getElementById("msg");
    const esc = (s) => (s||"").replace(/[&<>"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));

    async function load() {
      const { data, error } = await supabase.from("blog_templum_members").select("*").order("created_at");
      if (error) { rows.innerHTML = `<tr><td colspan="4" style="color:#b91c1c;padding:24px;">${error.message}</td></tr>`; return; }
      rows.innerHTML = data.length ? data.map(m => `
        <tr><td><b>${esc(m.full_name)||"—"}</b></td><td class="muted">${esc(m.email)}</td>
        <td><span class="pill ${m.role==="admin"?"pill--pub":"pill--draft"}">${m.role}</span></td>
        <td style="text-align:right;"><button class="btn btn--ghost btn--sm" data-rm="${m.id}">Remover</button></td></tr>`).join("")
        : '<tr><td colspan="4" class="muted" style="padding:24px;">Só você por enquanto.</td></tr>';
      rows.querySelectorAll("[data-rm]").forEach(b => b.addEventListener("click", async () => {
        if (!confirm("Remover colaborador?")) return;
        await supabase.from("blog_templum_members").delete().eq("id", b.dataset.rm); load();
      }));
    }
    await load();

    // Convidar = Edge Function "blog-invite" (usa service_role p/ criar o usuário no Auth).
    document.getElementById("invite").addEventListener("click", async () => {
      msg.textContent = "Convidando…";
      const body = { name: document.getElementById("name").value, email: document.getElementById("email").value, role: document.getElementById("role").value };
      if (!body.email) { msg.textContent = "Informe o e-mail."; return; }
      const { error } = await supabase.functions.invoke("blog-invite", { body });
      if (error) msg.textContent = "Erro (a Edge Function 'blog-invite' já está no ar?): " + error.message;
      else { msg.textContent = "Convite enviado ✓"; load(); }
    });
  </script>
</Cms>

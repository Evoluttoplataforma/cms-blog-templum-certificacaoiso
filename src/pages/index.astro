---
import Cms from "../layouts/Cms.astro";
---
<Cms title="Artigos — CMS Templum">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
    <h1 style="font-size:24px;font-weight:800;">Artigos</h1>
    <a href="/post/" class="btn">+ Novo artigo</a>
  </div>
  <div style="margin-bottom:14px;"><input id="q" placeholder="Buscar por título…" style="max-width:320px;" /></div>
  <div class="card">
    <table>
      <thead><tr><th>Título</th><th>Categoria</th><th>Status</th><th>Publicado</th><th></th></tr></thead>
      <tbody id="rows"><tr><td colspan="5" class="muted" style="padding:24px;">Carregando…</td></tr></tbody>
    </table>
  </div>
  <p class="muted" id="count" style="margin-top:12px;"></p>

  <script>
    import { supabase, requireAuth } from "../lib/supabase.js";
    await requireAuth();
    const rows = document.getElementById("rows"), countEl = document.getElementById("count");
    let all = [];
    const fmt = (d) => d ? new Date(d).toLocaleDateString("pt-BR", { day:"2-digit", month:"short", year:"numeric" }) : "—";
    const esc = (s) => (s||"").replace(/[&<>"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));
    function render(list) {
      if (!list.length) { rows.innerHTML = '<tr><td colspan="5" class="muted" style="padding:24px;">Nenhum artigo.</td></tr>'; return; }
      rows.innerHTML = list.map(p => `
        <tr>
          <td><a href="/post/?id=${p.id}"><b>${esc(p.title)}</b></a></td>
          <td class="muted">${esc(p.category_name)||"—"}</td>
          <td><span class="pill ${p.status==="published"?"pill--pub":"pill--draft"}">${p.status==="published"?"Publicado":"Rascunho"}</span></td>
          <td class="muted">${fmt(p.published_at)}</td>
          <td style="text-align:right;"><a class="btn btn--ghost btn--sm" href="/post/?id=${p.id}">Editar</a></td>
        </tr>`).join("");
    }
    const { data, error } = await supabase
      .from("blog_templum_posts")
      .select("id,title,category_name,status,published_at")
      .order("published_at", { ascending:false, nullsFirst:false })
      .limit(500);
    if (error) { rows.innerHTML = `<tr><td colspan="5" style="color:#b91c1c;padding:24px;">${error.message}</td></tr>`; }
    else { all = data; render(all); countEl.textContent = `${all.length} artigos`; }
    document.getElementById("q").addEventListener("input", (e) => {
      const t = e.target.value.toLowerCase();
      render(all.filter(p => p.title.toLowerCase().includes(t)));
    });
  </script>
</Cms>
